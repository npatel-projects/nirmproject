{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "backend/main.py": {
      "runtime": "python3.12"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/backend/main.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
